NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Passkey / WebAuthn auth
# Full site origin the browser reports (scheme + host + optional port).
WEBAUTHN_ORIGIN=http://localhost:3000
# Effective domain passkeys bind to (no scheme/port). Defaults to the origin host.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Empire OS
# Internal owner identity used to mint the Supabase session (not shown in UI).
OWNER_EMAIL=owner@empire.local
# Break-glass recovery code. When set, a locked-out owner (lost/replaced
# device) can clear stored passkeys from the login screen and re-register.
# Leave unset to disable recovery entirely. Generate: openssl rand -hex 16
OWNER_RECOVERY_CODE=

# OPENAI_API_KEY also enables Empire Recorder's audio transcription (Whisper) —
# translation/analysis fall back to whichever text provider is configured below.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Requesty is the preferred cloud router when configured.
REQUESTY_API_KEY=
REQUESTY_BASE_URL=https://router.requesty.ai/v1
REQUESTY_DEFAULT_MODEL=
REQUESTY_FAST_MODEL=
REQUESTY_STANDARD_MODEL=
REQUESTY_DEEP_MODEL=
REQUESTY_VISION_MODEL=

# LM Studio local/private fallback. This only works when the LM Studio server is
# running and reachable from the EmpireOS server. A phone alone cannot run it.
LMSTUDIO_ENABLED=false
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_DEFAULT_MODEL=
LMSTUDIO_FAST_MODEL=

# Free-tier fallback providers (OpenAI-API-compatible). Any the AI layer can
# fail over to when a paid quota is exhausted. All have no-card free tiers:
#   Groq      https://console.groq.com/keys
#   Cerebras  https://cloud.cerebras.ai/
#   OpenRouter https://openrouter.ai/keys  (use ':free' models)
#   Mistral   https://console.mistral.ai/
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# AI V2 model selection (optional — Anthropic defaults used when unset).
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_FAST_MODEL=claude-haiku-4-5-20251001
AI_JUDGE_MODEL=claude-sonnet-4-6

# Encrypts user-entered AI provider API keys at rest (AES-256-GCM).
# Optional: base64-encoded 32 bytes. If unset, a key is derived from
# SUPABASE_SERVICE_ROLE_KEY. Generate: openssl rand -base64 32
AI_PROVIDER_ENCRYPTION_KEY=
