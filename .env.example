NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Passkey / WebAuthn auth
# Full site origin the browser reports (scheme + host + optional port).
WEBAUTHN_ORIGIN=http://localhost:3000
# Effective domain passkeys bind to (no scheme/port). Defaults to the origin host.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Empire OS
# Internal owner identity used to mint the Supabase session (not shown in UI).
OWNER_EMAIL=owner@empire.local

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# AI V2 model selection (optional — Anthropic defaults used when unset).
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_FAST_MODEL=claude-haiku-4-5-20251001
AI_JUDGE_MODEL=claude-sonnet-4-6
